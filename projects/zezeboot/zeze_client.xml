<?xml version="1.0" encoding="utf-8"?>

<!-- client进程不需要定义ServerId; NoDatabase="true"表示不需要数据库,也不需要事务支持 -->
<zeze name="client" ServerId="0" NoDatabase="true">
	<ServiceConf ReceiveBuffer="64k" SendBuffer="64k" InputBufferMaxProtocolSize="max" OutputBufferMaxSize="100m"/> 默认配置

	<ServiceConf Name="LinkClient" ReceiveBuffer="64k" SendBuffer="32k" InputBufferMaxProtocolSize="10m" OutputBufferMaxSize="10m" RsaPubKey=""> 连接link
		<Connector HostNameOrAddress="127.0.0.1" Port="11000" IsAutoReconnect="true"/>
	</ServiceConf>
</zeze>
